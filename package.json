{
  "name": "logleads-login-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "webpack serve --mode development --no-client-overlay --hot --progress --color --port 8080 --config webpack.dev.js",
    "build": "mkdir -p build && webpack --config webpack.prod.js --mode production",
    "prettier": "prettier --write src/**/*.{vue,ts}",
    "lint": "eslint --quiet src/**/*.{vue,ts}",
    "lint:fix": "eslint src/**/*.{vue,ts} --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.7.9",
    "vue": "^3.5.13",
    "vue-loader": "^17.4.2",
    "vuex": "^4.1.0",
    "vuex-module-decorators": "^2.0.0"
  },
  "devDependencies": {
    "@types/webpack-env": "^1.18.5",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.32.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^3.4.2",
    "sass": "^1.83.1",
    "sass-loader": "^16.0.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write",
      "eslint --ext .ts --ext .vue",
      "git add"
    ]
  }
}
